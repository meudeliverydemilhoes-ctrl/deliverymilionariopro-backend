{
  "name": "deliverymilionariopro-backend",
  "version": "1.0.0",
  "description": "Backend for DeliveryMilionariopro SaaS - WhatsApp delivery management with AI",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon --exec node --loader tsx src/index.ts",
    "build": "tsc",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "migrate:make": "knex migrate:make",
    "seed": "knex seed:run",
    "seed:make": "knex seed:make",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "delivery",
    "whatsapp",
    "ai",
    "saas"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@types/node": "^20.0.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.14.0",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.1.2",
    "knex": "^3.1.0",
    "multer": "^1.4.5",
    "node-cron": "^3.0.2",
    "pg": "^8.11.3",
    "redis": "^4.6.12",
    "socket.io": "^4.7.2",
    "typescript": "^5.3.3",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/bull": "^3.15.9",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "eslint": "^8.55.0",
    "nodemon": "^3.0.2",
    "tsx": "^4.6.2"
  }
}
