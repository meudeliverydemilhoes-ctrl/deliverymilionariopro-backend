# ============================================
# DELIVERY MILIONÁRIO PRO - Configuração
# ============================================
# COPIE este arquivo para .env e preencha:
#   cp .env.example .env
# ============================================

# ---- BANCO DE DADOS ----
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/deliverymilionario

# ---- REDIS (fila de disparos) ----
REDIS_URL=redis://localhost:6379

# ---- JWT (autenticação) ----
# Gere uma chave segura: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TROQUE-POR-UMA-CHAVE-SEGURA-AQUI

# ============================================
# 👇 EVOLUTION API - SUA CONFIGURAÇÃO REAL
# ============================================
# URL da sua Evolution API (Railway)
EVOLUTION_API_URL=https://evolution-api-production-36e1.up.railway.app

# 👇 Cole aqui sua API Key da Evolution API
# (aquela chave mascarada que aparece no painel)
EVOLUTION_API_KEY=SUA_CHAVE_EVOLUTION_API_AQUI

# Nome da instância no Evolution API
EVOLUTION_INSTANCE_NAME=meudelivery

# URL do webhook (troque pelo seu domínio quando fizer deploy)
WEBHOOK_URL=https://seu-backend.com/api/v1/whatsapp/webhook

# ============================================
# 👇 ANTHROPIC (Claude IA - Chatbot)
# ============================================
# Crie sua chave em: https://console.anthropic.com/settings/keys
# 1. Acesse console.anthropic.com
# 2. Crie uma conta (se ainda não tem)
# 3. Vá em Settings > API Keys
# 4. Clique "Create Key"
# 5. Cole a chave aqui (começa com sk-ant-)
ANTHROPIC_API_KEY=sk-ant-SUA_CHAVE_ANTHROPIC_AQUI

# ---- SERVIDOR ----
PORT=3000
NODE_ENV=development

# ---- CORS ----
CORS_ORIGIN=http://localhost:3001

# ---- UPLOADS ----
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./uploads

# ---- LOGS ----
LOG_LEVEL=debug
